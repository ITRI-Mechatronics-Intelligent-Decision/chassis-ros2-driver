<?xml version="1.0" encoding="utf-8"?>
<robot name="chassis" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════
       Chassis geometry parameters
  ══════════════════════════════════════════════ -->
  <xacro:property name="front_x"   value="0.27732"  />  <!-- wheelbase/2 front  (m) -->
  <xacro:property name="rear_x"    value="-0.27268" />  <!-- wheelbase/2 rear   (m) -->
  <xacro:property name="track_y"   value="0.31105"  />  <!-- half track width   (m) -->
  <xacro:property name="wheel_z"   value="0.0765"   />  <!-- wheel axis height  (m) -->
  <xacro:property name="wheel_radius" value="0.2032"  />  <!-- wheel radius, 16" diameter (m) -->


  <!-- Wheel inertia (ixx == izz for axisymmetric wheel) -->
  <xacro:property name="front_wheel_mass"  value="11.628" />
  <xacro:property name="front_wheel_ixx"   value="0.16498" />
  <xacro:property name="front_wheel_iyy"   value="0.30566" />

  <xacro:property name="rear_wheel_mass"   value="11.607" />
  <xacro:property name="rear_wheel_ixx"    value="0.16443" />
  <xacro:property name="rear_wheel_iyy"    value="0.30566" />

  <!-- ═══════════════════════════════════════════
       Wheel macro
       params:
         name      — prefix used for link/joint/mesh names (e.g. front_left)
         x         — joint origin X
         y         — joint origin Y (positive = left)
         axis_y    — spin axis Y component: +1 for left wheels, -1 for right
         mass      — wheel mass (kg)
         ixx       — ixx = izz moment of inertia (kg·m²)
         iyy       — iyy spin-axis moment of inertia (kg·m²)
         com_y     — centre-of-mass Y offset from joint origin (m)
         color     — "r g b" string for visual colour
         joint_rpy — joint origin orientation (default: "0 0 0")
  ══════════════════════════════════════════════ -->
  <xacro:macro name="wheel" params="name x y axis_y mass ixx iyy com_y color joint_rpy:='0 0 0'">
    <link name="wheel_${name}_link">
      <inertial>
        <origin xyz="0 ${com_y} 0" rpy="0 0 0" />
        <mass value="${mass}" />
        <inertia
          ixx="${ixx}"  ixy="0" ixz="0"
          iyy="${iyy}"  iyz="0"
          izz="${ixx}" />
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://chassis_description/meshes/DD-s/wheel_${name}_link.STL" />
        </geometry>
        <material name="wheel_${name}_color">
          <color rgba="${color} 1" />
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0" />
        <geometry>
          <mesh filename="package://chassis_description/meshes/DD-s/wheel_${name}_link.STL" />
        </geometry>
      </collision>
    </link>

    <joint name="wheel_${name}_joint" type="continuous">
      <origin xyz="${x} ${y} ${wheel_z}" rpy="${joint_rpy}" />
      <parent link="base_link" />
      <child  link="wheel_${name}_link" />
      <axis xyz="0 ${axis_y} 0" />
    </joint>
  </xacro:macro>

    <!-- ═══════════════════════════════════════════
       Base footprint link
  ══════════════════════════════════════════════ -->  

  <link name="base_footprint"/>

<joint name="base_footprint_joint" type="fixed">
  <parent link="base_footprint" />
  <child  link="base_link" />
  <origin xyz="0 0 ${wheel_radius - wheel_z}" rpy="0 0 0" />
</joint>

  <!-- ═══════════════════════════════════════════
       Base link
  ══════════════════════════════════════════════ -->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0031731 -0.0002491 0.14649" rpy="0 0 0" />
      <mass value="11.221" />
      <inertia
        ixx="0.33572"  ixy="-3.5828E-09" ixz="-0.00054353"
        iyy="0.54427"  iyz="-4.2841E-07"
        izz="0.69255" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://chassis_description/meshes/DD-s/base_link.STL" />
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://chassis_description/meshes/DD-s/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- ═══════════════════════════════════════════
       Wheel instances
  ══════════════════════════════════════════════ -->
  <xacro:wheel name="front_left"
               x="${front_x}"  y="${track_y}"   axis_y="1"
               mass="${front_wheel_mass}" ixx="${front_wheel_ixx}" iyy="${front_wheel_iyy}"
               com_y="-0.001691"
               color="0.50196 0.50196 0.50196" />

  <xacro:wheel name="front_right"
               x="${front_x}"  y="${-track_y}"  axis_y="-1"
               mass="${front_wheel_mass}" ixx="${front_wheel_ixx}" iyy="${front_wheel_iyy}"
               com_y="0.001691"
               color="0.50196 0.50196 0.50196" />

  <xacro:wheel name="rear_left"
               x="${rear_x}"   y="${track_y}"   axis_y="1"
               mass="${rear_wheel_mass}"  ixx="${rear_wheel_ixx}"  iyy="${rear_wheel_iyy}"
               com_y="-0.0011969"
               color="0.50196 0.50196 0.50196" />

  <xacro:wheel name="rear_right"
               x="${rear_x}"   y="${-track_y}"  axis_y="-1"
               mass="${rear_wheel_mass}"  ixx="${rear_wheel_ixx}"  iyy="${rear_wheel_iyy}"
               com_y="0.0011969"
               color="0.50196 0.50196 0.50196"/>

</robot>
